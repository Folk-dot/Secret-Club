<!DOCTYPE html>
<html>
    <head>
        <title></title>
    </head>
    <body>
        <h1>Enter our secret passcode</h1>
        <form action="/join-club" method="post">
            <label for="passcode">
                <input id="passcode" name="passcode" type="password" pattern="\d{6}" maxlength="6" required>
            </label>
            <button type="submit">Enter</button>
            <a href="/">Cancel</a>
        </form>
    </body>
</html>