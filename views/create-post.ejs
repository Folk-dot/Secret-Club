<!DOCTYPE html>
<html>
    <head>
        <title>Create post</title>
    </head>
    <body>
        <h1>New post</h1>
        <%- include('partial/error.ejs') %>   
        <form action="/create" method="post">
            <label for="message">
                <textarea type="text" id="message" name="message" placeholder="Please type something..."></textarea>
            </label>
            <button type="submit">Create</button>
            <a href="/">Cancel</a>
        </form>
    </body>
</html>